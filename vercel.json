{
  "services": {
    "frontend": {
      "root": "pizza-frontend"
    },
    "backend": {
      "root": "pizza-backend",
      "entrypoint": "server.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}